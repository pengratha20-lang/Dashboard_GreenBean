# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=your_very_secure_random_secret_key_here_min_32_chars
DEBUG=False

# Database
# Local development
DATABASE_URL=sqlite:///app.db
# Render production example (set from Render Postgres service)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session & Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# ==================== BAKONG PAYMENT GATEWAY ====================
# Get these from Bakong Developer Portal: https://developer.bakong.khqr.io
BAKONG_API_KEY=your-bakong-api-key-here
BAKONG_ACCOUNT_ID=merchant@bank
BAKONG_MERCHANT_NAME=Green Bean
BAKONG_MERCHANT_CITY=PHNOM PENH
BAKONG_ACQUIRING_BANK=Your Bank Name
BAKONG_MERCHANT_ID=your-merchant-id
BAKONG_MOBILE_NUMBER=
BAKONG_STORE_LABEL=Green Bean
BAKONG_MERCHANT_CATEGORY_CODE=5999
BAKONG_WEBHOOK_SECRET=your-webhook-secret-for-verification

# Stripe Payment (Legacy - Optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Telegram Bot (Optional - for alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Configuration (Optional - for email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password_here

# Application Settings
MAX_CONTENT_LENGTH=2097152
ALLOW_REGISTRATION=True

# Security Logging
LOG_LEVEL=INFO
SECURITY_LOG_PATH=/var/log/greenbean/security.log

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://
PAYMENT_ENDPOINT_RATE_LIMIT=5 per minute
